local player = Players.LocalPlayer

local playerGui = player:WaitForChild("PlayerGui")
local ammoGui = playerGui:WaitForChild("AmmoGui")
local ammoText = ammoGui:WaitForChild("AmmoText")
local shootButton = ammoGui:WaitForChild("ShootButton")
local fireModeFrame = ammoGui:WaitForChild("FireModeFrame")
local fireModeButton = fireModeFrame:WaitForChild("FireModeButton")
local crosshair = ammoGui:FindFirstChild("Crosshair")

if crosshair then
	crosshair.AnchorPoint = Vector2.new(0.5, 0.5)
	crosshair.Position = UDim2.new(0.5, 0, 0.5, 0)

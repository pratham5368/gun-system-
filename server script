local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Debris = game:GetService("Debris")

local gunSystem = ReplicatedStorage:WaitForChild("GunSystem")
local Gun = require(gunSystem:WaitForChild("Gun"))
local gunRemote = gunSystem:WaitForChild("GunRemote")
local hitRemote = gunSystem:WaitForChild("HitRemote")

local guns = {}

local gunConfigs = {
	Pistol = {
		Name = "Pistol",
		Damage = 20,
		MaxAmmo = 12,
		FireRate = 0.3,
		ReloadTime = 1.5,
		Range = 300,
	},
}

local function getGun(player, gunName)
	guns[player] = guns[player] or {}

	if not guns[player][gunName] then
		local config = gunConfigs[gunName]
		if not config then return nil end
		guns[player][gunName] = Gun.new(config)
	end

	return guns[player][gunName]
end

local function createTracer(origin, hitPosition)
	local tracer = Instance.new("Part")
	tracer.Anchored = true
	tracer.CanCollide = false
	tracer.Material = Enum.Material.Neon
	tracer.Color = Color3.fromRGB(255, 230, 100)

	local distance = (hitPosition - origin).Magnitude
	tracer.Size = Vector3.new(0.08, 0.08, distance)
	tracer.CFrame = CFrame.lookAt(origin, hitPosition) * CFrame.new(0, 0, -distance / 2)
	tracer.Parent = workspace

	Debris:AddItem(tracer, 0.05)
end

local function getCharacterFromHit(part)
	local current = part
	while current do
		local humanoid = current:FindFirstChildOfClass("Humanoid")
		if humanoid then return current, humanoid end
		current = current.Parent
	end
	return nil, nil
end

local function performShot(player, gun, muzzleOrigin, aimOrigin, aimDirection)
	local character = player.Character
	if not character then return end

	if typeof(muzzleOrigin) ~= "Vector3" then return end
	if typeof(aimOrigin) ~= "Vector3" then return end
	if typeof(aimDirection) ~= "Vector3" then return end
	if aimDirection.Magnitude <= 0 then return end

	aimDirection = aimDirection.Unit

	local raycastParams = RaycastParams.new()
	raycastParams.FilterDescendantsInstances = { character }
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	raycastParams.IgnoreWater = true

	local cameraResult = workspace:Raycast(aimOrigin, aimDirection * gun.Range, raycastParams)
	local targetPosition = cameraResult and cameraResult.Position
		or (aimOrigin + aimDirection * gun.Range)

	local trueDirection = (targetPosition - muzzleOrigin).Unit
	local bulletResult = workspace:Raycast(muzzleOrigin, trueDirection * gun.Range, raycastParams)
	local hitPosition = bulletResult and bulletResult.Position
		or (muzzleOrigin + trueDirection * gun.Range)

	local hitType = "None"
	local isHeadshot = false

	if bulletResult then
		local hitCharacter, humanoid = getCharacterFromHit(bulletResult.Instance)
		if humanoid and hitCharacter ~= character then
			humanoid:TakeDamage(gun.Damage)
			hitType = "Player"
			isHeadshot = bulletResult.Instance.Name == "Head"
			print(player.Name .. " hit " .. hitCharacter.Name .. " with " .. gun.Name)
			if isHeadshot then print("HEADSHOT!") end
		else
			hitType = "Object"
		end
	end

	hitRemote:FireClient(player, hitType, isHeadshot)
	createTracer(muzzleOrigin, hitPosition)
end

local function shoot(player, gunName, muzzleOrigin, aimOrigin, aimDirection)
	local gun = getGun(player, gunName)
	if not gun then return end

	local didShoot = gun:Shoot()
	if not didShoot then return end

	performShot(player, gun, muzzleOrigin, aimOrigin, aimDirection)
end

local function burstShoot(player, gunName, muzzleOrigin, aimOrigin, aimDirection)
	local gun = getGun(player, gunName)
	if not gun then return end

	-- bypass fire rate check for burst shots
	gun.LastShotTime = 0
	local didShoot = gun:Shoot()
	if not didShoot then return end

	performShot(player, gun, muzzleOrigin, aimOrigin, aimDirection)
end

local function reload(player, gunName)
	local gun = getGun(player, gunName)
	if not gun then return end
	gun:Reload()
end

gunRemote.OnServerEvent:Connect(function(player, action, gunName, muzzleOrigin, aimOrigin, aimDirection)
	if action == "Shoot" then
		shoot(player, gunName, muzzleOrigin, aimOrigin, aimDirection)
	elseif action == "BurstShoot" then
		burstShoot(player, gunName, muzzleOrigin, aimOrigin, aimDirection)
	elseif action == "Reload" then
		reload(player, gunName)
	end
end)
